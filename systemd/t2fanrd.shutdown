#!/bin/sh
# Release each tracked fan to SMC auto at the very end of shutdown. By the
# time this runs, the daemon has long exited (it intentionally left fans in
# manual=1 at their last-commanded RPM) and all services + non-root mounts
# have been torn down — fans have had ample wall-clock time to settle, so
# no explicit sleeps are needed here.
for f in /sys/devices/pci*/*/*/*/APP0001:00/fan*_manual; do
    [ -f "$f" ] || continue
    echo 0 > "$f" 2>/dev/null
done
exit 0
